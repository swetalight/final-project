# =====================================================
# Конфигурация окружения
# =====================================================

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9094,localhost:9096
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512

# === Пути к SSL сертификатам (относительные) ===
KAFKA_SSL_CA=secrets/kafka.truststore.pem
KAFKA_SSL_CERT=secrets/kafka.keystore.pem
KAFKA_SSL_KEY=secrets/kafka.keystore.key

# === Пользователи ===
SHOP_USERNAME=shop
SHOP_PASSWORD=shop123
CLIENT_USERNAME=client
CLIENT_PASSWORD=client456
PROCESSOR_USERNAME=processor
PROCESSOR_PASSWORD=processor789
ANALYTICS_USERNAME=analytics
ANALYTICS_PASSWORD=analytics321
ADMIN_USERNAME=admin
ADMIN_PASSWORD=uosieQu6ACie0eichoo5ohdeeWaepowa

# === Elasticsearch ===
ELASTICSEARCH_HOST=localhost:9200
ELASTICSEARCH_INDEX=products

# === HDFS ===
HDFS_URL=hdfs://localhost:9000
HDFS_PATH=/data/products

# === Spark ===
SPARK_APP_NAME=MarketplaceAnalytics
SPARK_MASTER=local[*]

# === Prometheus ===
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin